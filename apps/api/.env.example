# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/nexus_dev

# ── Redis ──
REDIS_URL=redis://default:devpassword@localhost:6379

# ── Auth ──
JWT_SECRET=<same-as-nextauth-secret>

# ── Geo Services ──
GEOIP2_DB_PATH=/app/data/GeoLite2-City.mmdb
ABUSEIPDB_KEY=<your-abuseipdb-api-key>

# ── Encryption ──
ENCRYPTION_KEY=<generate-with-python-c-from-cryptography.fernet-import-Fernet-print-Fernet.generate_key>

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]

# ── OpenTelemetry ──
OTEL_ENDPOINT=http://tempo:4317
